# whisper.cpp binary (homebrew installs as `whisper-cli`)
WHISPER_BIN=/opt/homebrew/bin/whisper-cli

# Local GGML Whisper model (large-v3-turbo quantized)
WHISPER_MODEL=/Users/jperr/Library/Application Support/com.prakashjoshipax.VoiceInk/WhisperModels/ggml-large-v3-turbo-q5_0.bin

# Where shorts get saved. Each source video gets its own subfolder underneath.
OUTPUT_DIR=./output
